# Copy to .env and fill in before: docker compose up -d
#
# Dokploy: set these in the Compose stack environment UI instead.
# Point each service at its public URL in Traefik.

# ─── Ports (optional — Dokploy usually routes via Traefik instead) ───────────
GATEWAY_PORT=3100
ADMIN_PORT=8080

# ─── Gateway runtime ─────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=production
LOG_LEVEL=info

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OCL_BASE_URL=https://api.openconceptlab.org
OCL_API_TOKEN=your-ocl-api-token
OCL_ORG=Tabibu

BUNDLE_CACHE_DIR=/app/.cache/bundles
OPS_API_KEY=change-me-in-production
ADMIN_API_KEY=change-me-in-production

# Public URL of the admin UI — required for browser CORS
ADMIN_CORS_ORIGINS=https://admin.yourdomain.com

# ─── Admin UI build args (baked in at image build time) ──────────────────────
# Public URL of the gateway API as seen by the browser
VITE_GATEWAY_URL=https://api.yourdomain.com
# Must match ADMIN_API_KEY above
VITE_ADMIN_API_KEY=change-me-in-production
