# Server
PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# Supabase (Gateway database — separate from hospital installs)
SUPABASE_URL=https://your-project.supabase.co
# Publishable key — used by the runtime gateway (respects RLS)
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Service role key — required for packaging CI (bypasses RLS for version writes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OCL — public instance used by default.
# Override OCL_BASE_URL to point at a self-hosted deployment when needed.
OCL_BASE_URL=https://api.openconceptlab.org
# Set it when authoring/curating concepts (packaging CI writes) or accessing private collections.
OCL_API_TOKEN=your-ocl-api-token
# OCL_ORG must match the org name you created on api.openconceptlab.org (default: Tabibu).
OCL_ORG=Tabibu

# Bundle cache (filesystem path for collection export cache)
BUNDLE_CACHE_DIR=./.cache/bundles

# Ops API (simple shared secret for internal rollout endpoints in v1)
OPS_API_KEY=change-me-in-production

# Admin API (shared secret for hospital management + upgrade admin endpoints)
ADMIN_API_KEY=change-me-in-production

# Browser origins allowed to call admin endpoints (comma-separated)
ADMIN_CORS_ORIGINS=http://localhost:5173
